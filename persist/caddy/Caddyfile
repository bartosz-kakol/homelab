assistant.home.lcl assistant.home.rmt assistant.home.dir {
	import custom_tls
	reverse_proxy http://127.0.0.1:8123
}

zigbee2mqtt.home.lcl zigbee2mqtt.home.rmt zigbee2mqtt.home.dir {
	import custom_tls
	reverse_proxy http://127.0.0.1:8080
}
