{
	order wake_on_lan before respond
}

(custom_tls) {
	tls /etc/caddy/certs/server-bundle.pem /etc/caddy/certs/server.key
}

:80 {
	reverse_proxy http://123.123.1.2:3923
}

fs.home.rmt fs.home.dir {
	import custom_tls
	wake_on_lan 10:ff:e0:cf:e6:0e 123.123.1.255
	reverse_proxy http://123.123.1.2:3923 {
		transport http {
			dial_timeout 10s
			read_timeout 10s
		}
	}
}

